{
  "$id": "https://raw.githubusercontent.com/alankyshum/semantic-diff/main/schemas/semantic-diff.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "AiCli": {
      "enum": [
        "claude",
        "copilot"
      ],
      "type": "string"
    },
    "CliConfig": {
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "CostEntry": {
      "description": "F20: cost rates for a single model, in USD per million tokens. User-overridable — the bundled defaults are best-guess and can be adjusted via the config file.",
      "properties": {
        "input_per_mtok": {
          "format": "double",
          "type": "number"
        },
        "output_per_mtok": {
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "input_per_mtok",
        "output_per_mtok"
      ],
      "type": "object"
    },
    "LlmProvider": {
      "enum": [
        "claude",
        "copilot",
        "cursor"
      ],
      "type": "string"
    }
  },
  "description": "Raw on-disk JSON shape. Stable kebab/nested layout; used for both load and save.\n\nNote: `save()` writes plain JSON; any hand-edited comments in the existing JSONC file will be lost on save.",
  "properties": {
    "claude": {
      "$ref": "#/definitions/CliConfig"
    },
    "copilot": {
      "$ref": "#/definitions/CliConfig"
    },
    "cost-table": {
      "additionalProperties": {
        "$ref": "#/definitions/CostEntry"
      },
      "description": "F20: per-model cost overrides. Keyed `\"<provider>:<model>\"`. Optional; missing entries fall back to the bundled defaults.",
      "type": "object"
    },
    "cursor": {
      "$ref": "#/definitions/CliConfig"
    },
    "llm-providers": {
      "items": {
        "$ref": "#/definitions/LlmProvider"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "preferred-ai-cli": {
      "anyOf": [
        {
          "$ref": "#/definitions/AiCli"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "title": "SemanticDiffConfig",
  "type": "object"
}
